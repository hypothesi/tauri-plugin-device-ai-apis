root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown files often use trailing spaces for line breaks
[*.md]
trim_trailing_whitespace = false

# Rust files generally use 4 spaces indentation
[*.rs]
indent_size = 4

# Makefiles always use tabs
[Makefile]
indent_style = tab
